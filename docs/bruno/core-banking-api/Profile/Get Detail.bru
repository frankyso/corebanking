meta {
  name: Get Detail
  type: http
  seq: 2
}

get {
  url: {{base_url}}/profile/detail
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Accept: application/json
  X-Device-Id: {{device_id}}
}

docs {
  # Get Profile Detail

  Menampilkan detail lengkap nasabah (individu: nama, alamat, KTP, dll).

  **Security**: AUTH (Bearer Token)
}
