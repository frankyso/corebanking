meta {
  name: Holidays
  type: http
  seq: 3
}

get {
  url: {{base_url}}/system/holidays
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Accept: application/json
  X-Device-Id: {{device_id}}
}

params:query {
  ~year: 2026
}

docs {
  # List Holidays

  Menampilkan daftar hari libur berdasarkan tahun.

  **Query Parameters**:
  - `year` (optional): Tahun (default: tahun berjalan)

  **Security**: AUTH (Bearer Token)
}
