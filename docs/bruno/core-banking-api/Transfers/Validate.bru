meta {
  name: Validate
  type: http
  seq: 1
}

post {
  url: {{base_url}}/transfers/validate
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
  Accept: application/json
  X-Device-Id: {{device_id}}
}

body:json {
  {
    "destination_account_number": "SA-0000002"
  }
}

docs {
  # Validate Transfer Destination

  Memvalidasi rekening tujuan transfer. Mengembalikan nama pemilik rekening.

  **Security**: AUTH (Bearer Token)
}
