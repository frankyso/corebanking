meta {
  name: Unread Count
  type: http
  seq: 2
}

get {
  url: {{base_url}}/notifications/unread-count
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Accept: application/json
  X-Device-Id: {{device_id}}
}

docs {
  # Unread Count

  Menampilkan jumlah notifikasi yang belum dibaca.

  **Security**: AUTH (Bearer Token)

  **Response** (200):
  ```json
  {
    "data": {
      "unread_count": 5
    }
  }
  ```
}
